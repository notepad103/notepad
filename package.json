{
  "name": "notepad",
  "version": "0.1.0",
  "description": "macOS notepad built with Electron + React + Tailwind CSS",
  "license": "MIT",
  "author": "notepad103",
  "repository": {
    "type": "git",
    "url": "https://github.com/notepad103/notepad.git"
  },
  "homepage": "https://github.com/notepad103/notepad",
  "bugs": {
    "url": "https://github.com/notepad103/notepad/issues"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env ELECTRON_RUN_AS_NODE=0 VITE_DEV_SERVER_URL=http://localhost:5173 node_modules/.bin/electron .",
    "build": "vite build",
    "pack": "npm run build && npx electron-builder --dir",
    "dist": "npm run build && npx electron-builder",
    "preview": "vite preview",
    "start": "electron ."
  },
  "build": {
    "appId": "com.notepad.app",
    "productName": "Notepad",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "dependencies": {
    "@tiptap/extension-image": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "better-sqlite3": "^12.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^37.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.6",
    "tailwindcss": "3.3.6",
    "typescript": "^5.7.3",
    "vite": "^4.5.5",
    "wait-on": "^7.2.0"
  }
}
